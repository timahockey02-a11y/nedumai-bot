BOT_TOKEN=your_telegram_bot_token
DEEPSEEK_API_KEY=your_deepseek_api_key

# Ключ Yandex Geosearch API (https://developer.tech.yandex.ru/).
# Если не задан — рестораны / спорт / природа уйдут на чистый DeepSeek.
YANDEX_PLACES_API_KEY=

# Публичный HTTPS URL Mini App (страница webapp/index.html на GitHub Pages).
# Если пусто — Mini App не подключается, бот работает в обычном режиме.
WEBAPP_URL=

# Опционально: твой Telegram-id, куда форвардить /feedback от пользователей.
# Узнать id: напиши боту @userinfobot.
ADMIN_CHAT_ID=

# Опционально: путь к SQLite-файлу. По умолчанию bot.db в рабочей директории.
# На Railway создай Volume и поставь DB_PATH=/data/bot.db, чтобы данные пережили перезапуск.
DB_PATH=bot.db

# Порт HTTP API для Mini App. Railway передаёт PORT автоматически.
PORT=8080

# Origin Mini App для CORS. Если webapp на GitHub Pages — оставь как есть.
WEBAPP_ORIGIN=https://timahockey02-a11y.github.io

# Локальная разработка: 1 = пропускать проверку Telegram initData (для curl/ngrok).
# В проде ОБЯЗАТЕЛЬНО оставить 0.
WEB_API_DEV_MODE=0
WEB_API_DEV_USER_ID=1
